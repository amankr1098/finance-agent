# Google OAuth (used by web flow + legacy single-user mode)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"   # legacy single-user only (optional once multi-user is live)

# Agent config
GEMINI_API_KEY="your-gemini-api-key"
SHEET_ID="your-google-sheet-id"
OPENROUTER_API_KEY="your-openrouter-api-key"

# Server
PORT="8080"
BACKEND_URL="http://localhost:8080"                # used to build OAuth redirect URI
FRONTEND_URL="http://localhost:5173"               # comma-separated list allowed for CORS

# Firebase Admin (Firestore + Auth)
# Paste either raw JSON or base64-encoded JSON of the service-account key.
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_PROJECT_ID=""

# App secret used to:
#  - encrypt refresh tokens at rest (AES-256-GCM)
#  - sign OAuth `state` HMAC
# Generate with: openssl rand -hex 32
APP_SECRET=""
