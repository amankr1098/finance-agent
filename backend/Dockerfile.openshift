FROM node:22-alpine AS builder

WORKDIR /app

# Disable corepack shims and install pnpm via npm for the build stage only
RUN corepack disable && npm install -g pnpm@10.33.2

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# ---------------------------------------------------------------------------
# Runtime stage — no pnpm, no corepack, just node + pre-installed node_modules
# ---------------------------------------------------------------------------
FROM node:22-alpine AS runner

WORKDIR /app

# Disable corepack shims in the runtime image
RUN corepack disable

# Copy installed deps from builder
COPY --from=builder /app/node_modules ./node_modules

# Copy source
COPY package.json tsconfig.json ./
COPY src/ ./src/

# OpenShift compatibility: allow arbitrary non-root UID (typically in gid 0)
# to read app files and write where needed.
# /app/tmp is used as TMPDIR because readOnlyRootFilesystem:true blocks /tmp.
RUN mkdir -p /app/tmp && chgrp -R 0 /app && chmod -R g=u /app

# Run as non-root by default
USER 1001

EXPOSE 8000

# Redirect tmp to /app/tmp (writable under readOnlyRootFilesystem) so tsx can
# create its IPC socket without needing /tmp.
ENV TMPDIR=/app/tmp

# Run tsx directly from node_modules — no pnpm/corepack involved at runtime
CMD ["node_modules/.bin/tsx", "src/server.ts"]
