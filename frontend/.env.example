# ── Local development (pnpm dev) ────────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
VITE_API_BASE_URL=http://localhost:8080

# ── Vercel deployment ────────────────────────────────────────────────────────
# In your Vercel frontend project, add these under
# Project Settings → Environment Variables.
# VITE_API_BASE_URL=https://<your-backend-project>.vercel.app
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Docker / Kubernetes runtime ───────────────────────────────────────────────
# entrypoint.sh reads these at container start to generate /config.js.
# Plain vars take precedence; VITE_* vars above are used as fallback.
# For local Docker: podman run --env-file .env  (VITE_* fallback kicks in)
# For Kubernetes: set these in your Deployment env / ConfigMap / Secret.
#
# API_BASE_URL=http://backend.<namespace>.svc.cluster.local:8080
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
