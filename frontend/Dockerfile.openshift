FROM node:22-alpine AS builder

WORKDIR /app

# Point corepack cache to a path inside /app so OpenShift's arbitrary UID
# (which cannot write to /tmp) can still resolve the package manager at runtime.
ENV COREPACK_HOME=/app/.corepack

# Enable corepack and install pnpm
RUN corepack enable && corepack prepare pnpm@10.33.2 --activate

# Install dependencies
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source and build
COPY . .
RUN pnpm build

# Production stage — serve with unprivileged nginx
FROM nginxinc/nginx-unprivileged:stable-alpine AS runner

USER root

# Copy built assets to nginx html dir
COPY --from=builder /app/dist /usr/share/nginx/html

# SPA fallback config for React Router
RUN printf 'server {\n\
    listen 8080;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

# Copy entrypoint that generates /config.js from env vars at container start
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh && \
    chgrp -R 0 /usr/share/nginx/html /etc/nginx /var/cache/nginx /var/run /entrypoint.sh && \
    chmod -R g=u /usr/share/nginx/html /etc/nginx /var/cache/nginx /var/run /entrypoint.sh

# Run as non-root user with root group
USER 101:0

EXPOSE 8080

ENTRYPOINT ["/entrypoint.sh"]
